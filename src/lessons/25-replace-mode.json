{
  "slug": "replace-mode",
  "title": "Replace Mode",
  "category": "editing",
  "order": 25,
  "intro": "`r` replaces a single character, but `R` enters Replace mode: everything you type overwrites what's under the cursor until you press `Esc`. Perfect for same-length edits — dates, ports, aligned columns — because nothing shifts sideways.",
  "summary": "Overwrite text in place.",
  "keys": [
    "R"
  ],
  "exercises": [
